# Copy to .env and adjust for your environment:
#   cp .env.example .env

# Logging verbosity (see env_logger docs)
RUST_LOG=info

# Days before inactive documents are removed from server memory
EXPIRY_DAYS=1

# Optional SQLite persistence. Omit to keep documents in memory only.
# Local dev:
# SQLITE_URI=sqlite://data/rustpad.db
# Production (absolute path recommended):
# SQLITE_URI=sqlite:///home/ubuntu/notepad/data/rustpad.db

# HTTP port for rustpad-server (default 3030)
# PORT=3030
